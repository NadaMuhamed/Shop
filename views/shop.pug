doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title #{docTitle}
        link(rel="stylesheet", href="/css/product.css")
        link(rel="stylesheet", href="/css/main.css")
    body 
        ul.nav
            li
                a(href="/").nav__item Shop
            li
                a(href="/admin/add-product").nav__item Add Product

        main.container
            if prods.length > 0
                each product in prods
                    section.card
                        h1.page-title #{product.title}
                        img(src="https://www.skiptomylou.org/wp-content/uploads/2022/12/how-to-draw-a-book-6-600x338.jpg", alt=product.title)
                        button.btn View Details
            else
                section.card
                    h1.page-title Shop
                    p.page-text No products found. Please add some products.